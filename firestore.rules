rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Gate: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'saharaekhalq@gmail.com' || 
        request.auth.token.email == 'mahirkhan52505@gmail.com' ||
        request.auth.token.email == 'manzar52505@gmail.com'
      );
    }

    // 2. Public Collections (Read for everyone, Write for Admins)
    
    match /campaigns/{campaignId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /gallery/{itemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /news/{newsId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /stats/{statId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // 3. Admin Profiles
    match /admins/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
  }
}
